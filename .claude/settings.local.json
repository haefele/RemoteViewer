{
  "permissions": {
    "allow": [
      "Bash(dotnet:*)",
      "Bash(apt-get:*)",
      "Bash(curl:*)",
      "Bash(chmod:*)",
      "Bash(wget:*)",
      "Bash(dir:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(del:*)",
      "Bash(powershell:*)",
      "Bash(git:*)",
      "Bash(Select-String:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:docs.avaloniaui.net)",
      "WebFetch(domain:aarnott.github.io)",
      "WebFetch(domain:eiriktsarpalis.github.io)",
      "WebFetch(domain:blog.nerdbank.net)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/session-start-dotnet-install.sh"
          }
        ]
      }
    ]
  }
}
