<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:dialogs="using:RemoteViewer.Client.Controls.Dialogs"
        xmlns:presenter="using:RemoteViewer.Client.Views.Presenter"
        x:Class="RemoteViewer.Client.Controls.Dialogs.ViewerSelectionDialog"
        x:DataType="dialogs:ViewerSelectionDialogViewModel"
        Title="Send File"
        Icon="/Assets/avalonia-logo.ico"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Border Padding="20"
            MinWidth="320"
            MaxWidth="400">

        <StackPanel Spacing="16">

            <!-- Header with icon badge and title -->
            <Grid ColumnDefinitions="Auto,*">
                <Border Grid.Column="0"
                        Width="40"
                        Height="40"
                        CornerRadius="10"
                        Margin="0,0,14,0"
                        Background="{DynamicResource ToastIconBadgeBrush}">
                    <mi:MaterialIcon Kind="FileUpload"
                                     Width="22"
                                     Height="22"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource ToastTransferAccentBrush}"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="Send File"
                               FontSize="15"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Select recipients"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </Grid>

            <!-- File info card -->
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    CornerRadius="8"
                    Padding="14">
                <Grid ColumnDefinitions="Auto,*">
                    <mi:MaterialIcon Grid.Column="0"
                                     Kind="File"
                                     Width="20"
                                     Height="20"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="{Binding FileName}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding FileName}"/>
                        <TextBlock Text="{Binding FileSizeFormatted}"
                                   FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Viewer selection list -->
            <StackPanel Spacing="8">
                <TextBlock Text="Recipients"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="2,0,0,0"/>

                <ItemsControl ItemsSource="{Binding Viewers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="presenter:PresenterViewerDisplay">
                            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Margin="0,0,0,6">
                                <CheckBox IsChecked="{Binding IsSelected}"
                                          Cursor="Hand">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <mi:MaterialIcon Kind="Account"
                                                         Width="16"
                                                         Height="16"
                                                         VerticalAlignment="Center"
                                                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                    </StackPanel>
                                </CheckBox>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Action buttons -->
            <Grid ColumnDefinitions="*,10,*">
                <!-- Cancel button -->
                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="14,10"
                        Click="OnCancelClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <mi:MaterialIcon Kind="Close" Width="16" Height="16"/>
                        <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Send button -->
                <Button Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Classes="accent"
                        Padding="14,10"
                        Click="OnSendClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <mi:MaterialIcon Kind="Send" Width="16" Height="16"/>
                        <TextBlock Text="Send" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

        </StackPanel>
    </Border>
</Window>
