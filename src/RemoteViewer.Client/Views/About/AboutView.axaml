<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:RemoteViewer.Client.Controls"
        xmlns:vm="using:RemoteViewer.Client.Views.About"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:mik="using:Material.Icons"
        x:Class="RemoteViewer.Client.Views.About.AboutView"
        x:DataType="vm:AboutViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="About Remote Viewer"
        Width="480"
        Height="560"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        DataContextChanged="Window_DataContextChanged"
        Closed="Window_Closed">

    <Grid RowDefinitions="Auto,*,Auto" Margin="{StaticResource DialogPaddingLarge}">

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Spacing="{StaticResource GapMD}" HorizontalAlignment="Center" Margin="0,8,0,24">
            <!-- Circular icon badge using design system -->
            <controls:IconBadge Icon="{x:Static mik:MaterialIconKind.RemoteDesktop}"
                                Size="Large"
                                BadgeBackground="{DynamicResource AccentBrush}"
                                IconForeground="White"/>

            <StackPanel Spacing="{StaticResource GapXS}" HorizontalAlignment="Center">
                <TextBlock Text="{Binding ApplicationName}"
                           Classes="title-large"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding Version, StringFormat='Version {0}'}"
                           Classes="body-small secondary"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding Copyright}"
                           Classes="small secondary"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Licenses Section -->
        <Border Grid.Row="1"
                Classes="card-lg">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="{StaticResource GapSM}" Margin="0,0,0,12">
                    <mi:MaterialIcon Kind="License"
                                     Width="{StaticResource IconSizeSM}"
                                     Height="{StaticResource IconSizeSM}"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="Third-Party Licenses"
                               Classes="header-small"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Licenses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ThirdPartyLicense">
                                <Border Margin="0,0,0,8"
                                        Classes="list-item">
                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   Classes="header-small"/>

                                        <Border Grid.Row="0" Grid.Column="1"
                                                Classes="text-badge"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LicenseName}"/>
                                        </Border>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                    Orientation="Horizontal"
                                                    Spacing="{StaticResource SectionGap}"
                                                    Margin="0,8,0,0">
                                            <HyperlinkButton NavigateUri="{Binding Url}"
                                                             Padding="0"
                                                             Cursor="Hand">
                                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource GapXS}">
                                                    <mi:MaterialIcon Kind="Web"
                                                                     Width="{StaticResource IconSizeXS}"
                                                                     Height="{StaticResource IconSizeXS}"
                                                                     VerticalAlignment="Center"/>
                                                    <TextBlock Text="Website"
                                                               Classes="small"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </HyperlinkButton>
                                            <HyperlinkButton NavigateUri="{Binding LicenseUrl}"
                                                             Padding="0"
                                                             Cursor="Hand">
                                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource GapXS}">
                                                    <mi:MaterialIcon Kind="FileDocument"
                                                                     Width="{StaticResource IconSizeXS}"
                                                                     Height="{StaticResource IconSizeXS}"
                                                                     VerticalAlignment="Center"/>
                                                    <TextBlock Text="License"
                                                               Classes="small"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </HyperlinkButton>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer Button -->
        <Button Grid.Row="2"
                Classes="action-secondary"
                HorizontalAlignment="Stretch"
                Margin="{StaticResource SpacingVerticalLG}"
                Command="{Binding CloseCommand}">
            <StackPanel Orientation="Horizontal" Spacing="{StaticResource IconTextGap}">
                <mi:MaterialIcon Kind="Close" Width="{StaticResource IconSizeSM}" Height="{StaticResource IconSizeSM}"/>
                <TextBlock Text="Close" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
