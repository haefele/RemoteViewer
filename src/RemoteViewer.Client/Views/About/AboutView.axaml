<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RemoteViewer.Client.Views.About"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:mik="using:Material.Icons"
        x:Class="RemoteViewer.Client.Views.About.AboutView"
        x:DataType="vm:AboutViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="About Remote Viewer"
        Width="480"
        Height="560"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        DataContextChanged="Window_DataContextChanged"
        Closed="Window_Closed">

    <Grid RowDefinitions="Auto,*,Auto" Margin="24">

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Spacing="12" HorizontalAlignment="Center" Margin="0,8,0,24">
            <!-- Circular icon badge -->
            <Border Background="{DynamicResource AccentBrush}"
                    CornerRadius="32"
                    Width="64"
                    Height="64"
                    HorizontalAlignment="Center">
                <mi:MaterialIcon Kind="{x:Static mik:MaterialIconKind.RemoteDesktop}"
                                 Width="32"
                                 Height="32"
                                 Foreground="White"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
            </Border>

            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="{Binding ApplicationName}"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding Version, StringFormat='Version {0}'}"
                           FontSize="13"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding Copyright}"
                           FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Licenses Section -->
        <Border Grid.Row="1"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                CornerRadius="12"
                Padding="16">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <mi:MaterialIcon Kind="License"
                                     Width="16"
                                     Height="16"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="Third-Party Licenses"
                               FontWeight="SemiBold"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Licenses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ThirdPartyLicense">
                                <Border Margin="0,0,0,8"
                                        Padding="14"
                                        Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                        CornerRadius="8">
                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"/>

                                        <Border Grid.Row="0" Grid.Column="1"
                                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LicenseName}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        </Border>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                    Orientation="Horizontal"
                                                    Spacing="16"
                                                    Margin="0,8,0,0">
                                            <HyperlinkButton NavigateUri="{Binding Url}"
                                                             Padding="0"
                                                             Cursor="Hand">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <mi:MaterialIcon Kind="Web"
                                                                     Width="12"
                                                                     Height="12"
                                                                     VerticalAlignment="Center"/>
                                                    <TextBlock Text="Website"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </HyperlinkButton>
                                            <HyperlinkButton NavigateUri="{Binding LicenseUrl}"
                                                             Padding="0"
                                                             Cursor="Hand">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <mi:MaterialIcon Kind="FileDocument"
                                                                     Width="12"
                                                                     Height="12"
                                                                     VerticalAlignment="Center"/>
                                                    <TextBlock Text="License"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </HyperlinkButton>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer Button -->
        <Button Grid.Row="2"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="14,10"
                Margin="0,16,0,0"
                Command="{Binding CloseCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <mi:MaterialIcon Kind="Close" Width="16" Height="16"/>
                <TextBlock Text="Close" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
